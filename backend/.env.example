# ─── Base de dados ───────────────────────────────────
DATABASE_URL="postgresql://inp_user:MUDAR_PASSWORD@localhost:5432/inp_psicotecnico"

# ─── Redis ───────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────
# Gerar com: openssl rand -base64 64
JWT_SECRET="GERAR_SECRET_FORTE_AQUI"
JWT_EXPIRES_IN="8h"

# ─── Email (Resend) ───────────────────────────────────
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXX"
EMAIL_FROM="Inscrições INP <inscricoes@inp.co.ao>"

# ─── URLs ────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"
# Em produção: https://inscricoes.inp.co.ao

# ─── Uploads ─────────────────────────────────────────
# Tamanho máximo por ficheiro em MB
UPLOAD_MAX_SIZE_MB=10
# Caminho absoluto para armazenar os ficheiros
UPLOAD_DIR="./uploads"

# ─── Servidor ────────────────────────────────────────
PORT=4000
NODE_ENV="development"
